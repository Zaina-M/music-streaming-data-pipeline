###############################################################################
# terraform.tfvars.example
#
# Copy this to `terraform.tfvars` and fill in your values.
# `terraform.tfvars` is gitignored to keep your email / account-specific
# values out of version control.
###############################################################################

aws_region   = "eu-west-1"
aws_profile  = "default"
project_name = "music-streaming"
environment  = "dev"
owner        = "your-name-or-team"

# REQUIRED — you will receive an AWS subscription-confirmation email at this
# address after the first `terraform apply`. You must click the confirm link
# before alerts will actually be delivered.
alert_email = "you@example.com"
